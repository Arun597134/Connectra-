# Vite Client Environment Variables
# Copy this file to `.env` in the same directory and replace with your real keys.

# Giphy API key (Get a free one at https://developers.giphy.com/)
VITE_GIPHY_API_KEY=your_giphy_api_key_here

# Tenor API key (Get a key at https://console.cloud.google.com/apis/library/tenor.googleapis.com)
VITE_TENOR_API_KEY=your_tenor_api_key_here
